{
  "name": "Minotaur DApp Connector",
  "description": "This Extension used to communicate any DApp with minotaur wallet",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_title": "Open the popup"
  },
  "icons": {
    "16": "logo192.png",
    "48": "logo192.png",
    "128": "logo192.png"
  },
  "permissions": [
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["./scripts/injector.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "./scripts/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["scripts/content.js"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ]
}
